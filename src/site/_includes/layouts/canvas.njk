{% extends "layouts/base.njk" %}

{% block content %}
<article class="canvas-page">
  <h1>{{ title | default(page.fileSlug) }}</h1>

  {% if canvasData and canvasData.nodes and canvasData.nodes.length %}
  <div class="canvas-wrapper hide">
    <svg class="canvas-background" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" patternUnits="userSpaceOnUse" width="25" height="25">
          <path d="M 25 0 L 0 0 0 25" fill="none" stroke="var(--background-modifier-border)" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>

    <div class="canvas">
      {# Edges SVG layer #}
      <svg class="canvas-edges" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <marker id="arrowhead" markerWidth="10" markerHeight="7" 
                  refX="10" refY="3.5" orient="auto">
            <polygon points="0 0, 10 3.5, 0 7" 
                     fill="var(--canvas-edge-color, var(--text-muted))" />
          </marker>
        </defs>
        {% for edge in canvasData.edges %}
          <path class="canvas-edge"
                data-from="{{ edge.fromNode }}"
                data-to="{{ edge.toNode }}"
                data-from-side="{{ edge.fromSide }}"
                data-to-side="{{ edge.toSide }}"
                fill="none"
                stroke="var(--canvas-edge-color, var(--text-muted))"
                stroke-width="2"
                marker-end="url(#arrowhead)" />
        {% endfor %}
      </svg>

      {# Nodes #}
      {% for node in canvasData.nodes %}
        <div class="canvas-node"
             data-id="{{ node.id }}"
             style="transform: translate({{ node.x }}px, {{ node.y }}px); width: {{ node.width }}px; height: {{ node.height }}px;">
          <div class="canvas-node-content">
            {% if node.type == "text" %}
              {{ node.text | markdown | safe }}
            {% elif node.type == "file" %}
              <a href="/notes/{{ node.file | replace('.md', '') | lower }}/">{{ node.file }}</a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
  {% else %}
  <p style="color: red">⚠ canvasData is null or has no nodes</p>
  {% endif %}
</article>
{% endblock %}