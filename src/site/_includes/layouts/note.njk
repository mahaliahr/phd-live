{% extends "layouts/base.njk" %}

{% block head %}
{{ super() }}
{% block customStyles %}{% endblock %}
{% endblock %}

{% block content %}
<article class="note">
  <h1>{{ title | formatDailyTitle | default(page.fileSlug) }}</h1>
  {% if isKanban %}
    {% kanban page.inputPath %}
  {% else %}
    {{ content | hideDataview | taggify | link | safe }}
    {% include "components/revisionhistory.njk" %}
  {% endif %}
</article>
{% endblock %}
