<div class="graph-toolbar">
  <div class="graph-controls">
    <button id="graph-zoomin" class="graph-btn" title="Zoom in (+)">
      <i icon-name="zoom-in" aria-hidden="true"></i>
    </button>
    <button id="graph-zoomout" class="graph-btn" title="Zoom out (-)">
      <i icon-name="zoom-out" aria-hidden="true"></i>
    </button>
    <button id="graph-zoomfit" class="graph-btn" title="Fit to view (0)">
      <i icon-name="maximize-2" aria-hidden="true"></i>
    </button>
    <button id="graph-reset" class="graph-btn" title="Reset view">
      <i icon-name="refresh-ccw" aria-hidden="true"></i>
    </button>
  </div>

  <div class="graph-hint">
    <span><i>Scroll to zoom • Drag to pan • Click node to open</i></span>
  </div>
</div>

<div id="graph-container" class="full-page"></div>

<script src="{{ '/assets/js/graph.js' | url }}" defer></script>