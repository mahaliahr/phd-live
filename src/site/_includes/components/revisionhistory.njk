{% set noteRevisions = revisions[page.fileSlug] %}
{% if noteRevisions and noteRevisions.revisions.length > 0 %}

<div class="revision-history">
  <div class="revision-history__header">
    <span class="revision-history__label">Revision history</span>
    <span class="revision-history__summary">
      {{ noteRevisions.revisions.length }} revision{% if noteRevisions.revisions.length !== 1 %}s{% endif %}
      {% if noteRevisions.noteDate %}· {{ noteRevisions.noteDate }}{% endif %}
    </span>
  </div>

  <p class="revision-history__explainer">The revisions below show how this note has changed over time.</p>

  {% for rev in noteRevisions.revisions %}
  {% if rev.added > 0 or rev.removed > 0 or loop.last %}
  <div class="revision-row">
    <button class="revision-toggle" aria-expanded="false">
      <span class="revision-date">{{ rev.date }}</span>
      <span class="revision-deltas">
        {% if loop.last %}
          <span class="delta delta--initial">initial</span>
        {% else %}
          {% if rev.added > 0 %}
            <span class="delta delta--added">+{{ rev.added }} words</span>
          {% endif %}
          {% if rev.removed > 0 %}
            <span class="delta delta--removed">−{{ rev.removed }} words</span>
          {% endif %}
        {% endif %}
      </span>
      <span class="revision-wordcount">{{ rev.wordCount }} words</span>
      <span class="revision-chevron" aria-hidden="true">▶</span>
    </button>
    <div class="revision-diff" hidden>
      {% if loop.last %}
        <span class="revision-diff__initial">First version — no previous revision to compare against.</span>
      {% else %}
        {{ rev.diff | renderDiff | safe }}
      {% endif %}
    </div>
  </div>
  {% endif %}
  {% endfor %}

</div>
{% endif %}