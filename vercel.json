{
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "buildCommand": "git fetch --unshallow || true && git rev-list --count HEAD && npm run build",
    "devCommand": "npm run start",
    "routes": [
        { "handle": "filesystem" },
        { "src": "/(.*)", "status": 404, "dest": "/404" }
    ]
}